# Intel Arc GPU — user configuration
# This file is loaded by llama-server.service as EnvironmentFile.
# Override any value from configs/env.sh here.

# Models directory
MODELS_DIR=__HOME__/models

# Active model (path to .gguf file)
DEFAULT_MODEL=__HOME__/models/Qwen3VL-8B-Instruct-Q8_0.gguf

# Vision projector — leave blank to disable multimodal
MMPROJ_PATH=__HOME__/models/mmproj-Qwen3VL-8B-Instruct-F16.gguf

# Server bind address and port
LLAMA_HOST=0.0.0.0
LLAMA_PORT=8080
