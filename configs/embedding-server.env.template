# llama.cpp embedding server configuration
# Appended to ~/.config/intel-gpu-inference/env by scripts/install-embedding.sh
# For full options, see: https://github.com/ggml-org/llama.cpp/blob/master/examples/server/README.md

# === llama.cpp Embedding Server ===

# Embedding model (path to .gguf file)
EMBEDDING_MODEL=__HOME__/models/nomic-embed-text-v1.5.Q8_0.gguf

# Server bind address and port
EMBEDDING_HOST=0.0.0.0
EMBEDDING_PORT=8085

# Context size for embedding model
EMBEDDING_CTX=8192
